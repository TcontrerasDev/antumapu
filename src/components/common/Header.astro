---
import Navbar from "./Navbar.astro";

interface Props {
    theme?: "light" | "dark";
    lang?: string;
}

const { theme = "dark", lang = "es" } = Astro.props;
---

<header
    id="main-header"
    class:list={[
        "w-full fixed top-0 z-50 transition-all duration-300",
        {
            "bg-navy-800": theme === "light",
        },
    ]}
>
    <Navbar lang={lang} />
</header>

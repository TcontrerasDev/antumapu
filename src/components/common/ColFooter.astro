---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="col-span-12 md:col-span-6 lg:col-span-3 flex mb-20 lg:justify-end">
  <div class="flex flex-col gap-5 items-start">
    {
      title && (
        <h3 class="text-2xl font-bold uppercase tracking-[1.4px] text-gold-500 w-max">
          {title}
        </h3>
      )
    }
    <slot />
  </div>
</div>

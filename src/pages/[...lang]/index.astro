---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "en" } },
  ];
}

const { lang = "es" } = Astro.params;

import Layout from "../../layouts/Layout.astro";
import Header from "../../components/common/Header.astro";
import HeroIndex from "../../components/features/home/HeroIndex.astro";
import Historia from "../../components/features/home/Historia.astro";
import Actividades from "../../components/features/home/Actividades.astro";
import ActividadesList from "../../components/features/home/ActividadesList.astro";
import ActividadesSkeleton from "../../components/ui/ActividadesSkeleton.astro";
import Repertorio from "../../components/features/home/Repertorio.astro";
import Noticias from "../../components/features/noticias/Noticias.astro";
import Footer from "../../components/common/Footer.astro";
import { wpApi } from "../../lib/wp";

const page = await wpApi.getPageBySlug("antumapu", lang);
if (!page) {
  throw new Error("Page 'antumapu' not found in WordPress");
}
---

<Layout title="Antumapu" lang={lang}>
  <Header theme="dark" lang={lang} />
  <main id="main-content" tabindex="-1" class="focus:outline-none">
    <HeroIndex
      antetitulo={page.acf.antetitulo || ""}
      title={page.title.rendered}
      bajada={page.content.rendered}
      txtBtn1={page.acf.botones?.text_boton || ""}
      linkBtn1={page.acf.botones?.pagina || ""}
      txtBtn2={page.acf.botones?.text_boton_2 || ""}
      linkBtn2={page.acf.botones?.pagina_2 || ""}
      imgBack={page._embedded?.["wp:featuredmedia"]?.[0]?.source_url || ""}
    />

    <Actividades
      title={page.acf.titulo_presentaciones || ""}
      bajada={page.acf.bajada_presentaciones || ""}
    >
      <ActividadesList lang={lang} server:defer>
        <ActividadesSkeleton slot="fallback" />
      </ActividadesList>
    </Actividades>

    <Historia
      title={page.acf.titulo_historia || ""}
      resumen={page.acf.resumen || ""}
      img={page.acf.imagen_seccion?.url || ""}
      alt={page.acf.imagen_seccion?.alt || ""}
      statText1={page.acf.estadisticas?.titulo_estadistica || ""}
      statText2={page.acf.estadisticas?.titulo_estadistica_2 || ""}
      statText3={page.acf.estadisticas?.titulo_estadistica_3 || ""}
      statNumber1={page.acf.estadisticas?.numero_estadistica || ""}
      statNumber2={page.acf.estadisticas?.numero_estadistica_2 || ""}
      statNumber3={page.acf.estadisticas?.numero_estadistica_3 || ""}
    />

    <Repertorio title={page.acf.titulo_obras || ""} bajada={page.acf.bajada_obras || ""} lang={lang} />

    <Noticias
      title={page.acf.titulo_noticias || ""}
      bajada={page.acf.bajada_noticias || ""}
      theme="light"
      lang={lang}
    />
  </main>
  <Footer lang={lang} />
</Layout>

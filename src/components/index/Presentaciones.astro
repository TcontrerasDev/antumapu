---
import CardPresentacion from '../cards/CardPresentacion.astro';

interface Props {
  title: string;
  bajada: string;
}

const { title, bajada } = Astro.props;

const presentaciones = [
  {
    url: new URL('https://ceacuchile.ticketplus.cl/events/aniversario-55-anos-ballet-antumapu'),
    dia: '20',
    mes: 'May',
    titulo: 'Gala astística 55°',
    obra: 'Virgen Del Milagro - Chiloé, archipiélago mágico',
    lugar: 'TEATRO UNIVERSIDAD DE CHILE',
    direccion: 'Providencia 43, Santiago',
    hora: '19:00'
  },
  {
    url: new URL('https://ceacuchile.ticketplus.cl/events/aniversario-55-anos-ballet-antumapu'),
    dia: '20',
    mes: 'May',
    titulo: 'Gala astística 55°',
    obra: 'Virgen Del Milagro - Chiloé, archipiélago mágico',
    lugar: 'TEATRO UNIVERSIDAD DE CHILE',
    direccion: 'Providencia 43, Santiago',
    hora: '19:00'
  },
  {
    url: new URL('https://ceacuchile.ticketplus.cl/events/aniversario-55-anos-ballet-antumapu'),
    dia: '20',
    mes: 'May',
    titulo: 'Gala astística 55°',
    obra: 'Virgen Del Milagro - Chiloé, archipiélago mágico',
    lugar: 'TEATRO UNIVERSIDAD DE CHILE',
    direccion: 'Providencia 43, Santiago',
    hora: '19:00'
  }
]
---

<section class="padding-section bg-sand-100">
  <div class="wrapper flex flex-col">
    <div class="pb-8 border-b border-navy-950 flex flex-col gap-4">
      <h2 class="text-navy-950 uppercase font-bold text-h2 max-sm:text-[40px] lg:w-lg">{title}</h2>
      <p class="text-navy-950/80 max-w-2xl">{bajada}</p>
    </div>
    <div class="flex flex-col justify-center">
      {presentaciones.map((presentacion) => (
        <CardPresentacion
          url={presentacion.url}
          dia={presentacion.dia}
          mes={presentacion.mes}
          titulo={presentacion.titulo}
          obra={presentacion.obra}
          lugar={presentacion.lugar}
          direccion={presentacion.direccion}
          hora={presentacion.hora}
        />
      ))}
    </div>
  </div>
</section>

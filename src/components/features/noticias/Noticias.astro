---
import NoticiasList from "./NoticiasList.astro";
import NoticiasSkeleton from "./NoticiasSkeleton.astro";

interface Props {
    title: string;
    bajada: string;
    theme?: "light" | "dark";
}

const { title, bajada, theme = "light" } = Astro.props;
---

<section
    class:list={[
        "padding-section",
        {
            "bg-sand-100": theme === "light",
            "bg-navy-950": theme === "dark",
        },
    ]}
>
    <div class="wrapper">
        <div class="pb-8 flex flex-col gap-4">
            <h2
                class:list={[
                    "h2-heading",
                    {
                        "text-navy-950": theme === "light",
                        "text-sand-100": theme === "dark",
                    },
                ]}
            >
                {title}
            </h2>
            <p
                class:list={[
                    {
                        "text-navy-950/80": theme === "light",
                        "text-white-soft/80": theme === "dark",
                    },
                    "max-w-2xl",
                ]}
            >
                {bajada}
            </p>
        </div>
        <NoticiasList theme={theme} server:defer>
            <NoticiasSkeleton theme={theme} slot="fallback" />
        </NoticiasList>
    </div>
</section>

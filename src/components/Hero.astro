---
interface Props {
  title: string;
  bajada: string;
  theme?: "light" | "dark";
}

const { title, bajada, theme = "dark" } = Astro.props;

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);

// Función para formatear nombres (guiones a espacios y capitalizar)
const formatName = (name: string) => {
  const withSpaces = name.replace(/-/g, ' ');
  return withSpaces.charAt(0).toUpperCase() + withSpaces.slice(1);
};

const breadcrumbs = segments.map((segment, index) => {
  const url = `/${segments.slice(0, index + 1).join("/")}`;
  return {
    name: formatName(segment),
    url,
    isLast: index === segments.length - 1
  };
});

const isObrasSubpage = segments[0] === "obras" && segments.length > 1;
---

<section
  class:list={[
    "h-max relative py-36",
    {
      "bg-hero-gradient": theme === "dark",
      "bg-sand-100": theme === "light",
    },
  ]}
>
  <div
    class="w-56 h-56 aspect-square absolute right-0 lg:right-80 top-42.75 rounded-[274px] bg-gold-500 blur-[175px]"
  >
  </div>
  <div class="wrapper flex flex-col justify-center gap-7 h-full relative z-10">
    <span class="text-gold-500 font-heading-2 tracking-[1.4px]">
      <a
        href="/"
        class:list={[
          {
            "text-white-soft!": theme === "dark",
            "text-navy-950": theme === "light",
          },
        ]}
        >Inicio /
      </a>
      {
        breadcrumbs.map((bc) => (
          bc.isLast ? (
            <span
              class:list={[
                {
                  "text-gold-500": theme === "dark",
                  "text-gold-700": theme === "light",
                },
              ]}
            >
              {" "}{bc.name}
            </span>
          ) : (
            <a
              href={bc.url}
              class:list={[
                {
                  "text-white-soft!": theme === "dark",
                  "text-navy-950": theme === "light",
                },
              ]}
            >
              {" "}{bc.name} /
            </a>
          )
        ))
      }
    </span>
    <h1
      class:list={[
        "font-heading-2 text-[64px] max-sm:text-h2 2xl:text-h1 lg:w-[70%]",
        {
          "text-white": theme === "dark",
          "text-navy-950": theme === "light",
        },
      ]}
      set:html={title}
    />
    <div
      class:list={[
        "text-[20px] w-3/5",
        {
          "text-white": theme === "dark",
          "text-navy-950": theme === "light",
        },
      ]}
      set:html={bajada}
    />
    <slot />
  </div>
</section>

---
import Section from "./Section.astro";

interface Props {
    title: string;
    content: string;
    img: string;
    alt: string;
    imageLeft?: boolean;
}

const { title, content, img, alt, imageLeft = false } = Astro.props;
---

<Section background="bg-navy-950">
    <div class="wrapper grid grid-cols-4 md:grid-cols-12 gap-5 items-start">
        <div class:list={["col-span-full lg:col-span-6 flex flex-col gap-6", imageLeft ? "lg:order-2" : "lg:order-1"]}>
            <h2 class="uppercase font-bold text-h2 max-sm:text-[40px] text-white reveal-text">{title}</h2>
            <p class="text-white-soft text-body prose reveal-text">{content}</p>
        </div>
        <div class:list={["col-span-full lg:col-span-6 overflow-hidden aspect-square lg:aspect-video rounded-sm", imageLeft ? "lg:order-1" : "lg:order-2"]}>
            <img src={img} alt={alt} class="w-full h-[120%] object-cover parallax-img scale-110">
        </div>
    </div>
</Section>
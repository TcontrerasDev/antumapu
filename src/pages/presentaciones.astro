---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import GridPrestaciones from "../components/presentaciones/GridPrestaciones.astro";
import CardPresentacionCol from "../components/cards/CardPresentacionCol.astro";
import { wpApi } from "../lib/wp";

const pagePresentaciones = await wpApi.getPageBySlug("presentaciones");

const dataPresentaciones: {
  title: { rendered: string };
  acf: {
    url: string;
    fecha_source: { formatted_value: string };
    obra: string;
    lugar: string;
    direccion: string;
    hora_source: { formatted_value: string };
  };
}[] = await wpApi.getPresentaciones();
---

<Layout title="Presentaciones">
  <Header theme="light" />
  <main>
    <Hero
      title={pagePresentaciones.title.rendered}
      bajada={pagePresentaciones.content.rendered}
      theme="light"
    />
    <GridPrestaciones>
      {
        dataPresentaciones.map((presentacion) => (
          <CardPresentacionCol
            url={presentacion.acf.url}
            fecha={presentacion.acf.fecha_source.formatted_value}
            titulo={presentacion.title.rendered}
            obra={presentacion.acf.obra}
            lugar={presentacion.acf.lugar}
            direccion={presentacion.acf.direccion}
            hora={presentacion.acf.hora_source.formatted_value}
          />
        ))
      }
    </GridPrestaciones>
  </main>
  <Footer />
</Layout>

{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/historia/?$",
			"dest": "_render"
		},
		{
			"src": "^/noticias/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/noticias/?$",
			"dest": "_render"
		},
		{
			"src": "^/obras/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/obras/?$",
			"dest": "_render"
		},
		{
			"src": "^/presentaciones/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}
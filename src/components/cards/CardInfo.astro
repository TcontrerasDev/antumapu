---
interface Props {
    title: string;
    description: string;
    img: string;
}

const { title, description, img } = Astro.props;
---

<article class="col-span-full md:col-span-2 lg:col-span-3 flex flex-col justify-between min-h-80 p-3" tabindex="0">
    <div class="mb-5">
        <h3 class="text-[20px] text-navy-950 mb-1">{title}</h3>
        <p class="text-body text-navy-950">{description}</p>
    </div>
    <div class="w-full">
        <img src={img} alt={title} class="w-full h-full object-cover">
    </div>
</article>
---interface Props {
  title: string;
  bajada: string;
}

const { title, bajada } = Astro.props;
---

<section class="padding-section bg-sand-100">
  <div class="wrapper flex flex-col">
    <div class="pb-8 border-b border-navy-950 flex flex-col gap-4">
      <h2 class="text-navy-950 uppercase font-bold text-h2 max-sm:text-[40px] lg:w-lg">{title}</h2>
      <p class="text-navy-950/80 max-w-2xl">{bajada}</p>
    </div>
    <div class="flex flex-col justify-center">
      <slot />
    </div>
  </div>
</section>

---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "en" } },
  ];
}

const { lang = "es" } = Astro.params;

import Layout from "../../layouts/Layout.astro";
import Header from "../../components/common/Header.astro";
import Hero from "../../components/common/Hero.astro";
import Footer from "../../components/common/Footer.astro";
import { wpApi } from '../../lib/wp';

const page = await wpApi.getPageBySlug('direccion', lang);
if (!page) {
  throw new Error("Page 'direccion' not found in WordPress");
}

function injectRevealClass(html: string): string {
  let processed = html;
  processed = processed.replace(
    /<(h[1-6]|p)\b([^>]*)/gi,
    (match, tag, attrs) => {
      if (/class=["']/i.test(attrs)) {
        return `<${tag}${attrs.replace(/class=(["'])(.*?)\1/i, 'class=$1$2 reveal-text$1')}`;
      } else {
        return `<${tag} class="reveal-text"${attrs}`;
      }
    }
  );
  processed = processed.replace(
    /<div\b([^>]*)/gi,
    (match, attrs) => {
      if (/class=["'][^"']*\bwp-block-column(?:s)?\b[^"']*["']/i.test(attrs)) {
        if (/class=["']/i.test(attrs)) {
          return `<div${attrs.replace(/class=(["'])(.*?)\1/i, 'class=$1$2 reveal-text$1')}`;
        } else {
          return `<div class="reveal-text"${attrs}`;
        }
      }
      return match;
    }
  );
  return processed;
}
---

<Layout title={page.title.rendered} lang={lang}>
  <Header theme="light" lang={lang} />
  <main class="bg-sand-100 pb-20">
    <Hero
      title={page.title.rendered}
      bajada=""
      theme="light"
    />
    
    <section>
      <div class="wrapper content-direccion">
        <div set:html={injectRevealClass(page.content.rendered)} />
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>

<style is:global>
  /* Estilos específicos para maquetación de Gutenberg */

  .content-direccion h2 {
    font-size: 20px;
    text-transform: uppercase;
    color: var(--color-navy-950);
    margin-top: 4rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid #997931;
    padding-bottom: 0.5rem;
    font-family: "Italiana", serif;
    -webkit-text-stroke: 1px #000000;
    letter-spacing: 2px;
    display: block;
    width: fit-content;
  }

  .content-direccion h2.has-text-align-right {
    margin-left: auto;
    border-bottom-color: var(--color-gold-500);
  }

  .content-direccion h3 {
    font-size: 1.75rem;
    color: var(--color-navy-800);
    margin-top: 1rem;
    margin-bottom: 1.5rem;
  }

  .content-direccion p {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-navy-950);
    margin-bottom: 1.5rem;
  }

  .content-direccion p:empty {
    display: none;
  }

  /* Alineación de texto genérica */
  .content-direccion .has-text-align-left { text-align: left; }
  .content-direccion .has-text-align-center { text-align: center; }
  .content-direccion .has-text-align-right { text-align: right; }

  /* Listas */
  .content-direccion ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .content-direccion ol {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  /* Grid de Columnas de Gutenberg */
  .content-direccion .wp-block-columns {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 767px) {
    .content-direccion .wp-block-column {
      flex-basis: auto !important;
    }
  }

  @media (min-width: 768px) {
    .content-direccion .wp-block-columns {
      flex-direction: row;
      gap: 3rem;
    }
  }

  .content-direccion .wp-block-column {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
  }

  /* Alineación vertical */
  .content-direccion .wp-block-column.is-vertically-aligned-top {
    align-self: flex-start;
  }
  .content-direccion .wp-block-column.is-vertically-aligned-center {
    align-self: center;
  }
  .content-direccion .wp-block-column.is-vertically-aligned-bottom {
    align-self: flex-end;
  }

  /* Imágenes de Gutenberg */
  .content-direccion .wp-block-image {
    margin: 0;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 8px;
  }

  .content-direccion .wp-block-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }
</style>


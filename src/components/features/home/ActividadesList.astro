---
import CardPresentacion from "../../ui/CardPresentacion.astro";
import { wpApi } from "../../../lib/wp";

interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props;

const dataPresentaciones: {
  title: { rendered: string };
  acf: {
    url: string;
    fecha_source: { formatted_value: string };
    obra: string;
    lugar: string;
    direccion: string;
    hora_source: { formatted_value: string };
  };
}[] = await wpApi.getPresentaciones(lang);
---

{
  dataPresentaciones.map((presentacion) => (
    <CardPresentacion
      url={presentacion.acf.url}
      fecha={presentacion.acf.fecha_source.formatted_value}
      titulo={presentacion.title.rendered}
      obra={presentacion.acf.obra}
      lugar={presentacion.acf.lugar}
      direccion={presentacion.acf.direccion}
      hora={presentacion.acf.hora_source.formatted_value}
    />
  ))
}

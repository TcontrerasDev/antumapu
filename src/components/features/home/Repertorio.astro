---
import CardObra from "../../ui/CardObra.astro";
import { wpApi } from "../../../lib/wp";
import { useTranslations } from "../../../lib/i18n";

interface Props {
  title: string;
  bajada: string;
  lang?: string;
}

const { title, bajada, lang = "es" } = Astro.props;
const t = useTranslations(lang);

const obras = await wpApi.getObras(lang);
---

<section class="bg-navy-950 padding-section">
  <div class="wrapper">
    <div class="mb-8 flex flex-col gap-4">
      <h2 class="text-white h2-heading reveal-text">{title}</h2>
      <p class="text-white-soft max-w-2xl reveal-text">{bajada}</p>
    </div>
    <div 
      class="flex overflow-x-auto gap-5 snap-x snap-mandatory pb-4 custom-scrollbar"
      data-lenis-prevent
    >
      {obras.map((obra) => (
        <div class="w-full shrink-0 md:w-[calc(50%-10px)] lg:w-[calc(33.333%-14px)] xl:w-[calc(25%-15px)] snap-start">
          <CardObra
            url={lang === "es" ? `obras/${obra.slug}` : `en/obras/${obra.slug}`}
            imgSrc={obra._embedded?.["wp:featuredmedia"]?.[0]?.source_url || ""}
            titulo={obra.title.rendered}
            descripcion={obra.excerpt.rendered}
          />
        </div>
      ))}
    </div>
    
    <div class="mt-4 flex justify-end lg:hidden">
      <button 
        type="button" 
        class="flex items-center gap-2 text-gold-500 animate-pulse scroll-indicator cursor-pointer hover:text-gold-400 active:scale-95 transition-all duration-200 select-none focus:outline-none focus-visible:ring-2 focus-visible:ring-gold-500 rounded p-1"
        aria-label="Deslizar repertorio"
      >
        <span class="text-sm font-heading-2 uppercase tracking-widest">{t("desliza")}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce-x">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  const slider = document.querySelector('.custom-scrollbar') as HTMLElement;
  const indicator = document.querySelector('.scroll-indicator') as HTMLElement;

  if (slider) {
    // Manejo del indicador
    if (indicator) {
      slider.addEventListener('scroll', () => {
        if (slider.scrollLeft > 20) {
          indicator.classList.add('opacity-0', 'transition-opacity', 'duration-500');
          setTimeout(() => indicator.remove(), 500);
        }
      }, { once: true });

      // Hacer que al hacer clic se desplace hacia la derecha por una obra
      indicator.addEventListener('click', () => {
        const firstCard = slider.querySelector('.snap-start') as HTMLElement;
        const scrollAmount = firstCard ? firstCard.offsetWidth + 20 : slider.clientWidth;
        slider.scrollBy({
          left: scrollAmount,
          behavior: 'smooth'
        });
      });
    }

    // Lógica de Scroll: SHIFT para horizontal, sin SHIFT para vertical (Lenis)
    slider.addEventListener('wheel', (e) => {
      if (e.shiftKey) {
        // Si presiona SHIFT, forzamos el scroll horizontal y evitamos el vertical
        e.preventDefault();
        slider.setAttribute('data-lenis-prevent', '');
        
        // Usamos scrollBy para mayor compatibilidad
        // Cuando SHIFT está presionado, algunos navegadores pasan el valor en deltaX y otros en deltaY
        const scrollAmount = e.deltaY || e.deltaX;
        
        slider.scrollBy({
          left: scrollAmount,
          behavior: 'smooth'
        });
      } else {
        // Si NO presiona SHIFT, quitamos la prevención para que Lenis haga el scroll vertical de la página
        slider.removeAttribute('data-lenis-prevent');
      }
    }, { passive: false });

    // Asegurarnos de restaurar el atributo al salir para evitar conflictos
    slider.addEventListener('mouseleave', () => {
      slider.setAttribute('data-lenis-prevent', '');
    });
  }
</script>

<style>
  @keyframes bounce-x {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(5px); }
  }
  .animate-bounce-x {
    animation: bounce-x 1s infinite;
  }
  /* Personalización de la barra de desplazamiento */
  .custom-scrollbar {
    scrollbar-color: #cda14d transparent; /* Firefox: thumb / track */
    scrollbar-width: thin;
  }

  /* Chrome, Edge, y Safari */
  .custom-scrollbar::-webkit-scrollbar {
    height: 8px;
  }

  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }

  .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: #cda14d; /* gold-500 */
    border-radius: 20px;
  }

  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background-color: #b38a3d; /* Un tono un poco más oscuro para el hover */
  }
</style>

---
import { url } from "astro:schema";
import ImgNoticia from "../../assets/chiliche.webp";
import CardNoticia from "../cards/CardNoticia.astro";
import CardDestacada from "../cards/CardNoticiaDestacada.astro";

interface Props {
    title: string;
    bajada: string;
    theme?: "light" | "dark";
}

const { title, bajada, theme = "light" } = Astro.props;

const noticias = [
    {
        url: new URL('https://ceacuchile.ticketplus.cl/events/aniversario-55-anos-ballet-antumapu'),
        imgSrc: ImgNoticia.src,
        fecha: '20 mayo 2026',
        titulo: 'Noticia 1',
        descripcion: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt'
    },
    {
        url: new URL('https://ceacuchile.ticketplus.cl/events/aniversario-55-anos-ballet-antumapu'),
        imgSrc: ImgNoticia.src,
        fecha: '20 mayo 2026',
        titulo: 'Noticia 1',
        descripcion: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt'
    },
    {
        url: new URL('https://ceacuchile.ticketplus.cl/events/aniversario-55-anos-ballet-antumapu'),
        imgSrc: ImgNoticia.src,
        fecha: '20 mayo 2026',
        titulo: 'Noticia 1',
        descripcion: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt'
    },
    {
        url: new URL('https://ceacuchile.ticketplus.cl/events/aniversario-55-anos-ballet-antumapu'),
        imgSrc: ImgNoticia.src,
        fecha: '20 mayo 2026',
        titulo: 'Noticia 1',
        descripcion: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt'
    },
    {
        url: new URL('https://ceacuchile.ticketplus.cl/events/aniversario-55-anos-ballet-antumapu'),
        imgSrc: ImgNoticia.src,
        fecha: '20 mayo 2026',
        titulo: 'Noticia 1',
        descripcion: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt'
    }, 
]
---

<section
    class:list={[
        "padding-section",
        {
            "bg-sand-100": theme === "light",
            "bg-navy-950": theme === "dark",
        },
    ]}
>
    <div class="wrapper">
        <div class="pb-8 flex flex-col gap-4">
            <h2
                class:list={[
                    "h2-heading",
                    {
                        "text-navy-950": theme === "light",
                        "text-sand-100": theme === "dark",
                    },
                ]}
            >
                {title}
            </h2>
            <p
                class:list={[
                    {
                        "text-navy-950/80": theme === "light",
                        "text-white-soft/80": theme === "dark",
                    },
                    "max-w-2xl",
                ]}
            >
                {bajada}
            </p>
        </div>
        <div class="grid gap-5 lg:grid-cols-12 items-baseline pb-8">
            {noticias.map((noticias, index) => {
                if(index === 0 ) {
                    return (
                        <CardDestacada
                            url={noticias.url}
                            imgSrc={noticias.imgSrc}
                            fecha={noticias.fecha}
                            titulo={noticias.titulo}
                            descripcion={noticias.descripcion}
                            theme={theme}
                        />
                    )
                }
            })}
            {noticias.map((noticias, index) => {
                if(index === 1 ) {
                    return (
                        <CardNoticia
                            url={noticias.url}
                            imgSrc={noticias.imgSrc}
                            fecha={noticias.fecha}
                            titulo={noticias.titulo}
                            descripcion={noticias.descripcion}
                            theme={theme}
                        />
                    )
                }
            })}
        </div>
        <div class="grid gap-5 lg:grid-cols-12">
            {noticias.map((noticia, index) => {
                if(index !== 0 && index !== 1) {
                    return (
                        <CardNoticia
                            url={noticia.url}
                            imgSrc={noticia.imgSrc}
                            fecha={noticia.fecha}
                            titulo={noticia.titulo}
                            descripcion={noticia.descripcion}
                            theme={theme}
                        />
                    )
                }
            })}
        </div>
    </div>
</section>

---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/common/Header.astro";
import Footer from "../../../components/common/Footer.astro";
import NoticiaDetalle from "../../../components/features/noticias/NoticiaDetalle.astro";
import { wpApi } from "../../../lib/wp";
import { getBreadcrumbs } from "../../../lib/utils";
import { useTranslations } from "../../../lib/i18n";

export const prerender = false;

const { lang = "es", slug } = Astro.params;
if (!slug) return Astro.redirect("/404");

// Obtención ultra-rápida de metadatos SEO y de cabecera
let noticiaMetadata = null;
try {
  noticiaMetadata = await wpApi.getNoticiaMetadataBySlug(slug, lang);
} catch (error) {
  console.error("Error fetching news metadata:", error);
}
if (!noticiaMetadata) return Astro.redirect("/404");

const t = useTranslations(lang);

const breadcrumbs = getBreadcrumbs(Astro.url.pathname).filter(
  (bc) => bc.name.toLowerCase() !== "en" && bc.name.toLowerCase() !== "es"
);

const bgClass = "bg-navy-950/10";
const textClass = "bg-navy-800/10";
const goldClass = "bg-gold-700/20";
---

<Layout title={noticiaMetadata.title.rendered} lang={lang}>
  <Header theme="light" lang={lang} />
  <main class="bg-sand-100 pt-30 pb-20">
    <section>
      <div class="wrapper">
        <!-- Migas de pan renderizadas de inmediato -->
        <span class="text-gold-500 font-heading-2 tracking-[1.4px]">
          <a
            href={lang === "es" ? "/" : `/${lang}`}
            class="text-navy-950"
            >{t("inicio")} /
          </a>
          {
            breadcrumbs.map((bc) =>
              bc.isLast ? (
                <span
                  class="text-gold-700"
                >
                  {" "}
                  {bc.name}
                </span>
              ) : (
                <a
                  href={bc.url}
                  class="text-navy-950"
                >
                  {" "}
                  {bc.name} /
                </a>
              ),
            )
          }
        </span>

        <!-- Título y descripción/extracto renderizados de inmediato (SEO) -->
        <h1
          class="text-navy-950 text-h2 lg:text-h1 font-heading-2 mt-4"
          set:html={noticiaMetadata.title.rendered}
        />
        <div
          class="text-[18px] lg:text-2xl pt-5 text-navy-950 w-full lg:w-3/4"
          set:html={noticiaMetadata.excerpt.rendered}
        />

        <!-- Contenido diferido (Server Island) con Esqueleto en línea -->
        <NoticiaDetalle slug={slug} lang={lang} server:defer>
          <div slot="fallback" class="animate-pulse flex flex-col gap-6 w-full pt-15">
            <div class="grid grid-cols-12 gap-5">
              {/* Esqueleto del Contenido Principal (col-span-9) */}
              <div class="col-span-full lg:col-span-9 flex flex-col gap-8">
                <div class="flex flex-col gap-3">
                  <div class={`h-4 rounded w-full ${textClass}`}></div>
                  <div class={`h-4 rounded w-full ${textClass}`}></div>
                  <div class={`h-4 rounded w-11/12 ${textClass}`}></div>
                  <div class={`h-4 rounded w-4/5 ${textClass}`}></div>
                </div>
                <div class={`h-80 rounded w-full ${bgClass} my-2`}></div>
                <div class="flex flex-col gap-3">
                  <div class={`h-4 rounded w-full ${textClass}`}></div>
                  <div class={`h-4 rounded w-full ${textClass}`}></div>
                  <div class={`h-4 rounded w-5/6 ${textClass}`}></div>
                  <div class={`h-4 rounded w-3/4 ${textClass}`}></div>
                </div>
              </div>

              {/* Esqueleto de la Barra Lateral (col-span-3) */}
              <div class="col-span-full lg:col-span-3 flex flex-col gap-5 p-5 h-max bg-navy-950">
                <div class="flex flex-col gap-4">
                  <div class={`h-6 rounded w-2/3 ${goldClass}`}></div>
                  <div class="h-4 rounded w-1/2 bg-white/20"></div>
                </div>
                <div class="flex flex-col gap-4">
                  <div class={`h-6 rounded w-1/2 ${goldClass}`}></div>
                  <div class="h-4 rounded w-1/3 bg-white/20"></div>
                </div>
                <div class="flex gap-2 pt-2">
                  <div class="h-6 rounded w-16 bg-white/10"></div>
                  <div class="h-6 rounded w-20 bg-white/10"></div>
                </div>
              </div>
            </div>
          </div>
        </NoticiaDetalle>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>

---
interface Props {
  texto: string;
  video: string;
}

const { texto, video } = Astro.props;
---

<div class="flex flex-col gap-10 col-span-full lg:col-span-7">
  <p class="text-base text-navy-950 whitespace-pre-line" set:html={texto} ></p>
  <div class="*:w-full *:h-120" set:html={video}></div>
</div>

---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "en" } },
  ];
}

const { lang = "es" } = Astro.params;

import Layout from "../../layouts/Layout.astro";
import Header from "../../components/common/Header.astro";
import Hero from "../../components/common/Hero.astro";
import RepObras from "../../components/features/obras/RepObras.astro";
import Cardrep from "../../components/ui/Cardrep.astro";
import Footer from "../../components/common/Footer.astro";
import { wpApi } from "../../lib/wp";

const pageObras = await wpApi.getPageBySlug("obras", lang);
if (!pageObras) {
  throw new Error("Page 'obras' not found in WordPress");
}
const obras = await wpApi.getObras(lang);
---

<Layout title="Obras" lang={lang}>
  <Header theme="dark" lang={lang} />
  <main id="main-content" tabindex="-1" class="focus:outline-none">
    <Hero
      title={pageObras.title.rendered}
      bajada={pageObras.content.rendered}
      theme="dark"
    />
    <RepObras>
      {
        obras.map((obra, index) => (
          <Cardrep
            url={lang === "es" ? `/obras/${obra.slug}` : `/en/obras/${obra.slug}`}
            numeracion={index + 1}
            ano={obra.acf.fecha_estreno_source?.formatted_value || ""}
            titulo={obra.title.rendered}
            description={obra.excerpt.rendered}
          />
        ))
      }
    </RepObras>
  </main>
  <Footer lang={lang} />
</Layout>

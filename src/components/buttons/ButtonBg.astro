---
interface Props {
	href: URL | string;   
}

const { href } = Astro.props;
---

<a
  href={href}
  class="w-fit font-heading-2 uppercase text[14px] px-8 py-4 bg-gold-500 border rounded-sm border-gold-500 text-navy-950 tracking-[1.4px] font-semibold hover:bg-transparent hover:text-gold-500 transition-colors duration-300 max-sm:text-[12px]"
  >
  <slot />
  </a
>